{
  "expo": {
    "name": "science-club-app",
    "slug": "science-club-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scienceclubapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "instagram",
          "instagram-stories",
          "instagram",
          "instagram-stories",
          "instagram",
          "instagram-stories"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.anonymous.scienceclubapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "package": "com.anonymous.scienceclubapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o Science Club acesse suas fotos para anexar o registro do treino.",
          "cameraPermission": "Permita que o Science Club use a camera para registrar a finalizacao do treino."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permita que o Science Club acesse sua localização para registrar a rota do treino.",
          "locationWhenInUsePermission": "Permita que o Science Club acesse sua localização para registrar a rota do treino."
        }
      ],
      "expo-notifications",
      [
        "react-native-share",
        {
          "ios": [
            "instagram",
            "instagram-stories"
          ],
          "android": [
            "com.instagram.android"
          ],
          "enableBase64ShareAndroid": true
        }
      ]
    ],
    "extra": {
      "instagramStoriesAppId": "1475005294170350",
      "router": {},
      "eas": {
        "projectId": "4fa4f6b7-a30a-474f-9457-919831726f2b"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
